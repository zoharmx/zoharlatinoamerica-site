{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/sefarad", "destination": "/ensayo/", "permanent": true },
    { "source": "/sefarad-pardes-invertido", "destination": "/ensayo/", "permanent": true },
    { "source": "/pelicula", "destination": "/#pelicula", "permanent": false },
    { "source": "/youtube", "destination": "https://www.youtube.com/channel/UCxBItTOHMtkunnfBugXFtAg", "permanent": false },
    { "source": "/facebook", "destination": "https://www.facebook.com/Zoharlatinoamericaescuela", "permanent": false },
    { "source": "/calendario", "destination": "https://calendar-app-eight-eta.vercel.app", "permanent": false },
    { "source": "/zivug", "destination": "https://calendar-app-eight-eta.vercel.app/mazal", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
